msgid "Score posting"
msgstr "Đăng điểm"

msgid "Do you want to post this score to the scoreboard?"
msgstr "Bạn có muốn đăng điểm của bạn lên bảng điểm không?"

msgid "Please input your name."
msgstr "Vui lòng nhập tên của bạn."

msgid "Name entry"
msgstr "Ô nhập tên"

#, python-format
msgid "This build of %(gamename)s does not support score posting. Sorry!"
msgstr "Bản dựng này của %(gamename)s không hỗ trợ đăng điểm. Xin lỗi!"

#, python-format
msgid ""
"There was an error while posting your score (%(error)s). Please try again "
"later."
msgstr "Đã xảy ra lỗi khi đăng điểm của bạn (%(error)s). Vui lòng thử lại sau."

msgid ""
"Your score was posted, but you were not ranked in. Better luck next time!"
msgstr ""
"Điểm của bạn đã được đăng, nhưng bạn không được xếp hạng. Chúc bạn may mắn "
"lần sau. Lí do là bạn chơi chưa tốt, tôi ngĩ vậy!"

#, python-format
msgid ""
"Congratulations! Your score has ranked in position %(pos)d! Keep up your "
"great work!"
msgstr ""
"Xin chúc mừng! Điểm của bạn đã xếp ở thứ hạng %(pos)d! Chên bảng điểm. Chơi "
"để leo rank thôi nào, cho cả thế giới biết, bạn bố đời thế nào đi!"

msgid "Yes"
